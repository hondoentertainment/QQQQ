{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install --omit=dev",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "embed.html", "use": "@vercel/static" },
    { "src": "styles.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" },
    { "src": "lib/analytics.js", "use": "@vercel/static" },
    { "src": "manifest.json", "use": "@vercel/static" },
    { "src": "sw.js", "use": "@vercel/static" },
    { "src": "icon.svg", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" },
    { "src": "data/**", "use": "@vercel/static" },
    {
      "src": "api/quotes.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "data/holdings.json"
      }
    }
  ],
  "routes": [
    { "src": "/api/quotes", "dest": "api/quotes.js" }
  ],
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [{ "key": "cache-control", "value": "no-cache" }]
    }
  ]
}
