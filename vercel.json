{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --omit=dev",
  "functions": {
    "api/quotes.js": {
      "includeFiles": "data/holdings.json"
    }
  },
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [{ "key": "cache-control", "value": "no-cache" }]
    }
  ]
}
