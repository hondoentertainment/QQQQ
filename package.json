{
  "name": "qqqq-component-tracker",
  "version": "1.3.0",
  "description": "Live components and monthly allocations of QQQQ (Invesco QQQ Trust / Nasdaq-100).",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node --env-file-if-exists=.env server.js",
    "dev": "REFRESH_MINUTES=30 node --env-file-if-exists=.env server.js",
    "refresh": "node --env-file-if-exists=.env scripts/fetch-holdings.js",
    "lint": "eslint .",
    "test": "node --test test/*.test.js",
    "test:e2e": "node --test e2e/*.test.js",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "smoke:prod": "node scripts/smoke-prod.mjs"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "vercel": "^54.3.0"
  }
}
